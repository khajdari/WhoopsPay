      "tool": {
        "driver": {
          "name": "ESLint",
          "informationUri": "https://eslint.org",
          "rules": [
            {
              "id": "no-unused-vars",
              "helpUri": "https://eslint.org/docs/latest/rules/no-unused-vars",
              "properties": {},
              "shortDescription": {
                "text": "Disallow unused variables"
              }
            },
            {
              "id": "no-undef",
              "helpUri": "https://eslint.org/docs/latest/rules/no-undef",
              "properties": {},
              "shortDescription": {
                "text": "Disallow the use of undeclared variables unless mentioned in `/*global */` comments"
              }
            },
            {
              "id": "sonarjs/no-duplicate-string",
              "helpUri": "https://sonarsource.github.io/rspec/#/rspec/S1192/javascript",
              "properties": {},
              "shortDescription": {
                "text": "String literals should not be duplicated"
              }
            },
            {
              "id": "@typescript-eslint/no-explicit-any",
              "helpUri": "https://typescript-eslint.io/rules/no-explicit-any",
              "properties": {},
              "shortDescription": {
                "text": "Disallow the `any` type"
              }
            },
            {
              "id": "@typescript-eslint/no-unsafe-assignment",
              "helpUri": "https://typescript-eslint.io/rules/no-unsafe-assignment",
              "properties": {},
              "shortDescription": {
                "text": "Disallow assigning a value with type `any` to variables and properties"
              }
            },
            {
              "id": "@typescript-eslint/no-unsafe-member-access",
              "helpUri": "https://typescript-eslint.io/rules/no-unsafe-member-access",
              "properties": {},
              "shortDescription": {
                "text": "Disallow member access on a value with type `any`"
              }
            },
            {
              "id": "@typescript-eslint/no-unsafe-call",
              "helpUri": "https://typescript-eslint.io/rules/no-unsafe-call",
              "properties": {},
              "shortDescription": {
                "text": "Disallow calling a value with type `any`"
              }
            },
            {
              "id": "security/detect-object-injection",
              "helpUri": "https://github.com/eslint-community/eslint-plugin-security/blob/main/docs/rules/detect-object-injection.md",
              "properties": {
                "category": "Possible Security Vulnerability"
              },
              "shortDescription": {
                "text": "Detects \"variable[key]\" as a left- or right-hand assignment operand."
              }
            },
            {
              "id": "sonarjs/cognitive-complexity",
              "helpUri": "https://sonarsource.github.io/rspec/#/rspec/S3776/javascript",
              "properties": {},
              "shortDescription": {
                "text": "Cognitive Complexity of functions should not be too high"
              }
            },
            {
              "id": "no-useless-escape",
              "helpUri": "https://eslint.org/docs/latest/rules/no-useless-escape",
              "properties": {},
              "shortDescription": {
                "text": "Disallow unnecessary escape characters"
              }
            },
            {
              "id": "no-case-declarations",
              "helpUri": "https://eslint.org/docs/latest/rules/no-case-declarations",
              "properties": {},
              "shortDescription": {
                "text": "Disallow lexical declarations in case clauses"
              }
            },
            {
              "id": "security/detect-non-literal-fs-filename",
              "helpUri": "https://github.com/eslint-community/eslint-plugin-security/blob/main/docs/rules/detect-non-literal-fs-filename.md",
              "properties": {
                "category": "Possible Security Vulnerability"
              },
              "shortDescription": {
                "text": "Detects variable in filename argument of \"fs\" calls, which might allow an attacker to access anything on your system."
              }
            },
            {
              "id": "no-prototype-builtins",
              "helpUri": "https://eslint.org/docs/latest/rules/no-prototype-builtins",
              "properties": {},
              "shortDescription": {
                "text": "Disallow calling some `Object.prototype` methods directly on objects"
              }
            },
            {
              "id": "no-misleading-character-class",
              "helpUri": "https://eslint.org/docs/latest/rules/no-misleading-character-class",
              "properties": {},
              "shortDescription": {
                "text": "Disallow characters which are made with multiple code points in character class syntax"
              }
            },
            {
              "id": "no-cond-assign",
              "helpUri": "https://eslint.org/docs/latest/rules/no-cond-assign",
              "properties": {},
              "shortDescription": {
                "text": "Disallow assignment operators in conditional expressions"
              }
            },
            {
              "id": "no-empty",
              "helpUri": "https://eslint.org/docs/latest/rules/no-empty",
              "properties": {},
              "shortDescription": {
                "text": "Disallow empty block statements"
              }
            },
            {
              "id": "@microsoft/sdl/no-msapp-exec-unsafe",
              "helpUri": "https://github.com/microsoft/eslint-plugin-sdl/blob/master/docs/rules/no-msapp-exec-unsafe.md",
              "properties": {},
              "shortDescription": {
                "text": "Calls to [`MSApp.execUnsafeLocalFunction()`](https://docs.microsoft.com/en-us/previous-versions/hh772324(v=vs.85)) bypass script injection validation and should be avoided."
              }
            },
            {
              "id": "@microsoft/sdl/no-inner-html",
              "helpUri": "https://github.com/microsoft/eslint-plugin-sdl/blob/master/docs/rules/no-inner-html.md",
              "properties": {},
              "shortDescription": {
                "text": "Assignments to [innerHTML](https://developer.mozilla.org/en-US/docs/Web/API/Element/innerHTML)/[outerHTML](https://developer.mozilla.org/en-US/docs/Web/API/Element/outerHTML) properties or calls to [insertAdjacentHTML](https://developer.mozilla.org/en-US/docs/Web/API/Element/insertAdjacentHTML) method manipulate DOM directly without any sanitization and should be avoided. Use document.createElement() or similar methods instead."
              }
            },
            {
              "id": "getter-return",
              "helpUri": "https://eslint.org/docs/latest/rules/getter-return",
              "properties": {},
