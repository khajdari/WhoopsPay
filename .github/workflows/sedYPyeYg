          else
            echo "  ❌ Permissions-Policy: MISSING"
            exit 1
          fi
          
          if echo "$SECURITY_HEADERS" | grep -q "Cross-Origin-Embedder-Policy: require-corp"; then
            echo "  ✅ Cross-Origin-Embedder-Policy: require-corp"
          else
            echo "  ❌ Cross-Origin-Embedder-Policy: MISSING"
            exit 1
          fi
          
          if echo "$SECURITY_HEADERS" | grep -q "Strict-Transport-Security:"; then
            echo "  ✅ HSTS Header: PRESENT (HTTPS enforcement)"
          else
            echo "  ❌ HSTS Header: MISSING"
            exit 1
          fi
          
          if echo "$SECURITY_HEADERS" | grep -q "X-Powered-By:"; then
            echo "  ❌ X-Powered-By: PRESENT (SECURITY LEAK)"
            exit 1
          else
            echo "  ✅ X-Powered-By: BLOCKED (GOOD)"
          fi
          
          echo "🎉 ALL HTTPS SECURITY HEADERS VERIFIED - READY FOR OWASP ZAP HTTPS SCAN"
        env:
          DAST_MODE: true
