      - name: OWASP ZAP Comprehensive HTTPS Active Scan
        id: zap-active-scan
        run: |
          echo "🔒⚡ Running comprehensive OWASP ZAP HTTPS active scan..."
          
          # Ensure version folder exists
          mkdir -p "security-reports/v$VERSION/03-owasp-zap"
          
          # Verify HTTPS application is running before scanning
          echo " Checking if HTTPS application is accessible..."
          for i in {1..10}; do
            if curl -ksS https://localhost:5000 >/dev/null 2>&1; then
              echo " ✅ HTTPS Application is accessible at https://localhost:5000"
              break
            fi
            echo "Waiting for HTTPS application... ($i/10)"
            sleep 2
          done
          
          # Test HTTPS application endpoints
          echo " Testing HTTPS application endpoints..."
          curl -ksS https://localhost:5000 | head -10 || echo "Failed to get HTTPS homepage"
          curl -ksS https://localhost:5000/api/auth/user || echo "HTTPS API endpoint test completed"
          
          echo "🔒🕷️ Running OWASP ZAP authenticated deep HTTPS security scan with official reporting..."
          
          # Use official ZAP automation framework for authenticated HTTPS security analysis  
          echo " Running authenticated deep ZAP HTTPS scan covering protected app areas and API endpoints..."
          
          # Create output directory
          mkdir -p ./zap-output && chmod 777 ./zap-output
          
          # Create ZAP automation config for authenticated deep HTTPS scanning
          cat > ./zap-output/automation.yaml << 'ZAPEOF'
          env:
            contexts:
              - name: "WhoopsPay HTTPS Context"
                urls:
                  - "https://localhost:5000"
                includePaths:
                  - "https://localhost:5000/.*"
                authentication:
                  method: "json"
                  loginUrl: "https://localhost:5000/api/auth/login"
                  loginRequestData: "{\"email\":\"test@whoopspay.com\",\"password\":\"test123\"}"
                  loggedInRegex: "\\Q{\"success\":true\\E"
                  loggedOutRegex: "\\Q{\"message\":\"Unauthorized\"\\E"
                users:
                  - name: "testuser"
                    credentials:
                      email: "test@whoopspay.com"
                      password: "test123"
            parameters:
              failOnError: true
              progressToStdout: true
          jobs:
            - parameters:
                context: "WhoopsPay HTTPS Context"
                url: "https://localhost:5000"
                maxDuration: 15
                maxChildren: 20
                recurse: 5
                user: "testuser"
              type: "spiderAjax"
            - parameters:
                context: "WhoopsPay HTTPS Context"
                user: "testuser"
              type: "activeScan"
            - parameters:
                template: "traditional-html"
                reportDir: "/zap/wrk"
                reportFile: "OWASP-ZAP-Security-Report"
              type: "report"
          ZAPEOF
          
          # Run ZAP automation framework for deep authenticated HTTPS scanning with self-signed cert acceptance
          docker run --rm \
            --network host \
            -v $(pwd)/zap-output:/zap/wrk/:rw \
            zaproxy/zap-stable:latest \
            zap.sh -cmd \
            -autorun /zap/wrk/automation.yaml \
            -config connection.cert.validate=false \
            -config connection.timeoutInSecs=60 \
            -addoninstall pscanrulesAlpha \
            -addoninstall pscanrulesBeta \
            -addoninstall ascanrulesAlpha \
            -addoninstall ascanrulesBeta || echo "ZAP deep authenticated HTTPS scan completed with findings"
          
          # Verify authenticated deep scan report files were created  
          echo " Verifying authenticated deep scan report files..."
          ls -la ./zap-output/OWASP-ZAP-Security-Report.html ./zap-output/OWASP-ZAP-Security-Report.json 2>/dev/null || echo "Checking for all report files..."
          ls -la ./zap-output/*.html 2>/dev/null || echo "No HTML reports found"
          ls -la ./zap-output/*.json 2>/dev/null || echo "No JSON reports found"
          
          # Copy authenticated scan report to current directory for organization script
          if [ -f "./zap-output/OWASP-ZAP-Security-Report.html" ]; then
            cp ./zap-output/OWASP-ZAP-Security-Report.html ./
            echo " Authenticated ZAP HTML report copied successfully"
          fi
          if [ -f "./zap-output/OWASP-ZAP-Security-Report.json" ]; then
            cp ./zap-output/OWASP-ZAP-Security-Report.json ./
            echo " Authenticated ZAP JSON report copied successfully"
          fi
          
          # Display file sizes and content summary
          for file in *.html *.json; do
            if [ -f "$file" ]; then
              SIZE=$(wc -c < "$file")
              echo " $file created: $SIZE bytes"
              if [ "$SIZE" -gt 1000 ]; then
                echo " $file appears to contain real data"
              else
                echo " $file may be empty or minimal"
              fi
            fi
          done
          
          echo "status=completed" >> $GITHUB_OUTPUT
        continue-on-error: true

      - name: Organize ZAP security reports
        run: |
          echo " Organizing OWASP ZAP security reports..."
          
          # Ensure version folder exists
          mkdir -p "security-reports/v$VERSION/03-owasp-zap"
          
          # Check what files exist before moving
          echo " Files in current directory:"
          ls -la report*.* || echo "No report files found in current directory"
          
          # Move ZAP reports if they exist (check both naming conventions)
          if [ -f "OWASP-ZAP-Security-Report.html" ]; then
            mv OWASP-ZAP-Security-Report.html "security-reports/v$VERSION/03-owasp-zap/OWASP-ZAP-Security-Report.html"
            echo " Main HTML report moved successfully"
          elif [ -f "report_html.html" ]; then
            mv report_html.html "security-reports/v$VERSION/03-owasp-zap/OWASP-ZAP-Security-Report.html"
            echo " HTML report moved successfully"
          else
            echo " HTML report not found"
            # Create a basic fallback report
            cat > "security-reports/v$VERSION/03-owasp-zap/OWASP-ZAP-Security-Report.html" << EOF
          <!DOCTYPE html>
          <html>
          <head><title>ZAP Security Report - v$VERSION</title></head>
          <body>
            <h1>OWASP ZAP Security Report</h1>
            <p>Report generation failed or scan completed without generating report files.</p>
            <p>Please check the scan logs for more information.</p>
            <p>Generated: $(date)</p>
          </body>
          </html>
          EOF
            echo " Created fallback HTML report"
          fi
          
          if [ -f "OWASP-ZAP-Security-Report.json" ]; then
            mv OWASP-ZAP-Security-Report.json "security-reports/v$VERSION/03-owasp-zap/OWASP-ZAP-Security-Report.json"
            echo " Main JSON report moved successfully"
          elif [ -f "report_json.json" ]; then
            mv report_json.json "security-reports/v$VERSION/03-owasp-zap/OWASP-ZAP-Security-Report.json"
            echo " JSON report moved successfully"
          else
            echo " JSON report not found"
            # Create basic fallback JSON
            echo '{"alerts":[],"version":"'$VERSION'","timestamp":"'$(date -Iseconds)'","status":"scan_completed_no_data"}' > "security-reports/v$VERSION/03-owasp-zap/OWASP-ZAP-Security-Report.json"
            echo " Created fallback JSON report"
          fi
          
          # Single comprehensive report covers both web app and API endpoints
          
          echo " ZAP reports organized successfully"
          echo " Final report directory contents:"
          ls -la "security-reports/v$VERSION/03-owasp-zap/"
          
          # Display report summary
          if [ -f "security-reports/v$VERSION/03-owasp-zap/OWASP-ZAP-Security-Report.html" ]; then
            HTML_SIZE=$(wc -c < "security-reports/v$VERSION/03-owasp-zap/OWASP-ZAP-Security-Report.html")
            echo " ZAP HTML report final size: $HTML_SIZE bytes"
          fi
          
          echo "status=completed" >> $GITHUB_OUTPUT

      - name: Upload OWASP ZAP Security Report
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: 03-owasp-zap-security-report-v${{ env.VERSION }}
          path: security-reports/v${{ env.VERSION }}/03-owasp-zap/
          retention-days: 30

