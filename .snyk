# Snyk policy file for WhoopsPay - FULL SECURITY SCANNING
version: v1.0.0

# NO IGNORES - Detect ALL vulnerabilities including educational ones
ignore: {}

# No patches applied
patch: {}

# Language settings
language-settings:
  javascript: true
  typescript: true

# Failure threshold - detect all severities
failureThreshold: low

# Minimal exclusions - only build artifacts
exclude:
  global:
    - '**/node_modules/**'
    - '**/dist/**'
    - '**/build/**'