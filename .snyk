# Snyk policy file for WhoopsPay educational security platform
version: v1.0.0

# Ignore educational vulnerabilities - these are intentional for training
ignore:
  SNYK-JS-*:
    - '**/*educational*/**':
        reason: 'Educational vulnerability for security training purposes'
        expires: '2025-12-31T23:59:59.999Z'
    - '**/*vulnerable*/**':
        reason: 'Intentional security demonstration code'
        expires: '2025-12-31T23:59:59.999Z'
    - '**/*demo*/**':
        reason: 'Demo vulnerability for training platform'
        expires: '2025-12-31T23:59:59.999Z'
    - '**/controllers/**':
        reason: 'Contains intentional educational vulnerabilities'
        expires: '2025-12-31T23:59:59.999Z'

# No patches applied
patch: {}

# Language settings
language-settings:
  javascript: true
  typescript: true

# Failure threshold - only fail on high severity real vulnerabilities
failureThreshold: high

# Exclude test files and documentation
exclude:
  global:
    - '**/*.test.*'
    - '**/test/**'
    - '**/tests/**'
    - '**/docs/**'
    - '**/*.md'