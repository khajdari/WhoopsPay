{
  "name": "owasp-juice-shop-integration",
  "version": "1.0.0",
  "description": "OWASP Juice Shop Integration with WhoopsPay",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "NODE_ENV=development tsx server/index.ts",
    "client": "vite",
    "start": "node dist/server/index.js",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "express-static-gzip": "^2.1.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0",
    "vite": "^5.0.0",
    "tailwindcss": "^3.3.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  }
}